<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.ui.MainController">
    <children>
        <Label layoutX="230.0" layoutY="20.0" text="DANH SÁCH ĐẤU GIÁ">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>
        <TableView fx:id="auctionTable" layoutX="30.0" layoutY="70.0" prefHeight="350.0" prefWidth="640.0">
            <columns>
                <TableColumn fx:id="colItem" prefWidth="200.0" text="Vật phẩm" />
                <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá hiện tại" />
                <TableColumn fx:id="colStatus" prefWidth="150.0" text="Trạng thái" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
        <Button layoutX="275.0" layoutY="440.0" onAction="#handleJoin" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #4CAF50;" text="Vào phòng" textFill="WHITE" />
    </children>
</AnchorPane>