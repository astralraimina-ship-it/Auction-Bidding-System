<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefHeight="700" prefWidth="1100"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.ui.tab.AdminController"
      style="-fx-background-color: #fff5f5;">

    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <!-- Header Admin -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #c0392b; -fx-padding: 15; -fx-background-radius: 10;">
        <VBox>
            <Label text="HỆ THỐNG QUẢN TRỊ VIÊN"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Quản trị toàn bộ sàn đấu giá UET" style="-fx-font-size: 13px; -fx-text-fill: #ecf0f1;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblBalance" text="MODE: ADMIN"
               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: white; -fx-padding: 5 15; -fx-border-radius: 20;" />
    </HBox>

    <TabPane fx:id="adminTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: white; -fx-background-radius: 10;">

        <!-- TAB 1: DUYỆT GIAO DỊCH -->
        <Tab text="Duyệt Nạp/Rút Tiền">
            <VBox spacing="15" style="-fx-padding: 15;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Yêu cầu giao dịch đang chờ xử lý" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- Nút Refresh cho Tab 1 -->
                    <Button fx:id="btnRefresh1" text="Làm mới bảng" onAction="#refreshData"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="tableTransactions" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTransUser" text="Người dùng" prefWidth="150" />
                        <TableColumn fx:id="colTransType" text="Loại" prefWidth="100" />
                        <TableColumn fx:id="colTransAmount" text="Số tiền gốc" prefWidth="150" />
                        <TableColumn fx:id="colTransNet" text="Thực nhận (-10%)" prefWidth="150" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button text="Từ chối" onAction="#handleRejectTrans"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand;" />
                    <Button text="Duyệt giao dịch" onAction="#handleApproveTrans"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand;" />
                </HBox>
            </VBox>
        </Tab>

        <!-- TAB 2: QUẢN LÝ NGƯỜI DÙNG -->
        <Tab text="Quản lý người dùng">
            <VBox spacing="15" style="-fx-padding: 15;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Danh sách tài khoản hệ thống" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- NÚT MỚI: Refresh cho Tab 2 -->
                    <Button text="Làm mới bảng" onAction="#refreshData"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUsername" text="Tên đăng nhập" prefWidth="200" />
                        <TableColumn fx:id="colRole" text="Vai trò" prefWidth="120" />
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="150" />
                        <TableColumn fx:id="colUserBalance" text="Số dư (VNĐ)" prefWidth="150" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button text="Khóa tài khoản" onAction="#handleBlockUser"
                            style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand;" />
                    <Button text="Duyệt Member" onAction="#handleApproveUser"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand;" />
                </HBox>
            </VBox>
        </Tab>

        <!-- TAB 3: QUẢN LÝ SẢN PHẨM -->
        <Tab text="Quản lý sản phẩm">
            <VBox spacing="10" style="-fx-padding: 15;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Danh sách sản phẩm đấu giá" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- NÚT MỚI: Refresh cho Tab 3 -->
                    <Button fx:id="btnRefresh" text="Làm mới bảng" onAction="#refreshData"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="tableItems" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="140" />
                        <TableColumn fx:id="colCategory" text="Loại" prefWidth="80" />
                        <TableColumn fx:id="colSeller" text="Người bán" prefWidth="110" />
                        <TableColumn fx:id="colDetails" text="Mô tả" prefWidth="140" />
                        <TableColumn fx:id="colStartPrice" text="Giá sàn" prefWidth="120" />
                        <TableColumn fx:id="colBinPrice" text="Giá mua đứt" prefWidth="120" />
                        <TableColumn fx:id="colTimeLeft" text="Trạng thái" prefWidth="150" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button text="Đăng xuất" onAction="#handleLogout"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand;" />
    </HBox>
</VBox>