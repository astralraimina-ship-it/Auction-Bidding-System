<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650" prefWidth="1000" spacing="20" style="-fx-background-color: #fff5f5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.ui.DashboardController">

    <padding>
        <Insets bottom="25" left="30" right="30" top="25" />
    </padding>

    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #c0392b; -fx-padding: 15; -fx-background-radius: 10;">
        <VBox>
            <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" text="HỆ THỐNG QUẢN TRỊ VIÊN" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #ecf0f1;" text="Quản trị toàn bộ sàn đấu giá UET" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblBalance" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: white; -fx-padding: 5 15; -fx-border-radius: 20;" text="MODE: ADMIN" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Quản lý sản phẩm">
            <VBox spacing="10" style="-fx-padding: 15;">
                <TableView fx:id="tableItems" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colItemName" prefWidth="200" text="Tên sản phẩm" />
                        <TableColumn fx:id="colCategory" prefWidth="120" text="Danh mục" />
                        <TableColumn fx:id="colDetails" prefWidth="400" text="Thông tin chi tiết" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Quản lý người dùng">
            <VBox spacing="15" style="-fx-padding: 15;">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Danh sách tài khoản" />

                    <Separator orientation="VERTICAL" prefHeight="20" />
                    <Label text="Lọc theo:" />
                    <ComboBox fx:id="comboFilter" onAction="#handleFilterChange" prefWidth="180.0" promptText="Tất cả người dùng" />

                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleApproveUser" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" text="Duyệt Admin" />
                </HBox>

                <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUsername" prefWidth="200" text="Tên đăng nhập" />
                        <TableColumn fx:id="colRole" prefWidth="120" text="Vai trò" />
                        <TableColumn fx:id="colStatus" prefWidth="150" text="Trạng thái" />
                        <TableColumn fx:id="colUserBalance" prefWidth="150" text="Số dư (VNĐ)" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#handleLogout" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25;" text="Đăng xuất" />
    </HBox>
</VBox>