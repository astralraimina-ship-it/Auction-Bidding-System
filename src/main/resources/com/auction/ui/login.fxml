<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/8"
      fx:controller="com.auction.ui.auth.LoginController"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="UET Auction System" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox spacing="15" maxWidth="300">
        <TextField fx:id="txtUsername" promptText="Tên đăng nhập"
                   style="-fx-padding: 10; -fx-background-radius: 5;"/>

        <PasswordField fx:id="txtPassword" promptText="Mật khẩu"
                       style="-fx-padding: 10; -fx-background-radius: 5;"/>
    </VBox>

    <!-- Thêm defaultButton="true" để nhấn Enter là tự đăng nhập -->
    <Button text="Đăng nhập" onAction="#handleLogin" defaultButton="true"
            style="-fx-padding: 10 50; -fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 5;"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Chưa có tài khoản?" />
        <Hyperlink text="Đăng ký ngay" onAction="#goToRegister"
                   style="-fx-text-fill: #2980b9; -fx-underline: false; -fx-font-weight: bold;"/>
    </HBox>

</VBox>