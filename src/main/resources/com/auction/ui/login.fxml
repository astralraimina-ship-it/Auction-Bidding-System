<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.ui.LoginController"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="UET Auction System" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox spacing="10" maxWidth="300">
        <TextField fx:id="txtUsername" promptText="Username" style="-fx-padding: 8;"/>
        <PasswordField fx:id="txtPassword" promptText="Password" style="-fx-padding: 8;"/>
    </VBox>

    <Button text="Login" onAction="#handleLogin"
            style="-fx-padding: 8 40; -fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Chưa có tài khoản?" />
        <Hyperlink text="Đăng ký ngay" onAction="#goToRegister" style="-fx-text-fill: #2980b9; -fx-underline: false;"/>
    </HBox>

</VBox>