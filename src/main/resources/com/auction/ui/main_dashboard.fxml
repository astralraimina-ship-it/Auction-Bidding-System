<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefHeight="650" prefWidth="1000"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.ui.DashboardController"
      style="-fx-background-color: #f4f7f6;">

    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox>
            <Label text="UET AUCTION - BIDDER"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2980b9;" />
            <Label text="Sàn đấu giá trực tuyến dành cho sinh viên" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
            <Label text="Số dư hiện có" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;" />
            <Label fx:id="lblBalance" text="0.00 VNĐ"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
        </VBox>
    </HBox>

    <TableView fx:id="tableItems" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5; -fx-font-size: 14px;">
        <columns>
            <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="180" />
            <TableColumn fx:id="colCategory" text="Loại hàng" prefWidth="100" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="colDetails" text="Thông tin chi tiết" prefWidth="320" />
            <TableColumn fx:id="colStartPrice" text="Giá sàn" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button text="Đăng xuất" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" />
    </HBox>
</VBox>