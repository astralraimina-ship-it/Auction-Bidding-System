<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefHeight="650" prefWidth="1100"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.ui.tab.SellerController"
      style="-fx-background-color: #fef9f3;">

    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox>
            <Label text="UET SELLER CENTER"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
            <Label text="Kênh quản lý sản phẩm người bán" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />

        <VBox alignment="CENTER_RIGHT" spacing="10">
            <VBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 10; -fx-border-color: #fad390; -fx-border-radius: 10;">
                <Label text="Số dư hiện có" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;" />
                <Label fx:id="lblBalance" text="0 VNĐ"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Nạp tiền" onAction="#handleOpenDeposit"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                        prefWidth="100" />
                <Button text="Rút tiền" onAction="#handleOpenWithdraw"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                        prefWidth="100" />
            </HBox>
        </VBox>
    </HBox>

    <TableView fx:id="tableItems" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
        <columns>
            <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="180" />
            <TableColumn fx:id="colCategory" text="Loại" prefWidth="80" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="colDetails" text="Mô tả hàng hóa" prefWidth="250" />

            <!-- Cột Giá sàn: Map với startingPrice trong Controller -->
            <TableColumn fx:id="colStartPrice" text="Giá sàn" prefWidth="130" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

            <!-- Cột Giá mua đứt: Map với binPrice trong Controller -->
            <TableColumn fx:id="colBinPrice" text="Giá mua đứt" prefWidth="130" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #c0392b;" />

            <!-- Cột Thời gian: Map với timeLeft trong Controller -->
            <TableColumn fx:id="colTimeLeft" text="Thời gian còn lại" prefWidth="150" style="-fx-alignment: CENTER;" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button text="+ Đăng sản phẩm" onAction="#onAddProduct"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 5; -fx-cursor: hand;" />
        <Button text="Đăng xuất" onAction="#handleLogout"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 5; -fx-cursor: hand;" />
    </HBox>
</VBox>