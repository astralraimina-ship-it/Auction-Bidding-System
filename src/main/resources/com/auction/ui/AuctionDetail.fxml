<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.ui.AuctionDetailController">
    <children>
        <Label fx:id="lblItemName" layoutX="30.0" layoutY="30.0" text="Tên vật phẩm">
            <font><Font name="System Bold" size="22.0" /></font>
        </Label>
        <Label layoutX="30.0" layoutY="80.0" text="Giá hiện tại: " />
        <Label fx:id="lblCurrentPrice" layoutX="110.0" layoutY="75.0" text="0.0" textFill="RED">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>
        <TextField fx:id="txtBidAmount" layoutX="30.0" layoutY="120.0" promptText="Nhập giá..." />
        <Button layoutX="190.0" layoutY="120.0" onAction="#handleBid" text="Đặt giá" />
        <TextArea fx:id="txtLogs" layoutX="30.0" layoutY="170.0" prefHeight="200.0" prefWidth="540.0" editable="false" />
    </children>
</AnchorPane>